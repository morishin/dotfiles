[init]
	defaultBranch = main
[color]
  ui = auto
	status = always
[core]
  editor = vim
  quotepath = false
  whitespace = trailing-space
  autocrlf = input
  pager = less -R
[pager]
  log = less -M
  show = less -M
  diff = less -M
[push]
  default = current
[merge]
  ff = false
[pull]
  rebase = true
[rerere]
  enabled = true
[gpg]
	program = gpg
[commit]
  gpgsign = true
	template = /Users/morishin/.stCommitMsg
[user]
	signingkey = 10A9FD8589A9523B4F8E11D91D72D0FFA7ECCBFB
	name = Shintaro Morikawa
	email = sntr92@gmail.com
[includeIf "gitdir:~/work/"]
  path = ~/.config/git/includes/config_cookpad
[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
