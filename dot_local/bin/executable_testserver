#!/usr/bin/env python3
import http.server as s
from urllib.parse import urlparse
from urllib.parse import parse_qs

class MyHandler(s.BaseHTTPRequestHandler):
    def do_POST(self):
        self.make_data(True)
    def do_GET(self):
        self.make_data(False)
    def make_data(self, is_post):
        parsed = urlparse(self.path)
        params = parse_qs(parsed.query)
        if is_post:
            content_len  = int(self.headers.get("content-length"))
            req_body = self.rfile.read(content_len).decode("utf-8")
        body  = "method: " + str(self.command) + "\n"
        body += "headers:" + "\n------------------------\n" + str(self.headers) + "------------------------\n"
        body += "params: " + str(params) + "\n"
        if is_post:
            body += "body  : " + req_body + "\n"
        print(body)
        res = body.encode()
        self.send_response(200)
        self.send_header('Content-type', 'text/html; charset=utf-8')
        self.send_header('Content-length', len(res))
        self.end_headers()
        self.wfile.write(res)

host = '0.0.0.0'
port = 8000
httpd = s.HTTPServer((host, port), MyHandler)
print('サーバを起動しました。ポート:%s' % port)
httpd.serve_forever()
