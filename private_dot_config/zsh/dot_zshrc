function load() {
  if [ -f $1 ]; then
    . $1
  fi
}

# work-machine settings from the private dotfiles-work submodule (skipped when absent)
load $HOME/develop/dotfiles/dotfiles-work/zsh/work.zsh

DOT_FILES=(
  env.zsh
  pathes.zsh
  common.zsh
  functions.zsh
  aliases.zsh
  completions.zsh
  starship.zsh
)

for file in ${DOT_FILES[@]}
do
  load $ZDOTDIR/$file
done
